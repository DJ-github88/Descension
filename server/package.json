{
  "name": "mythrill-server",
  "version": "1.0.0",
  "description": "Multiplayer backend for Mythrill D&D VTT",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint *.js services/*.js handlers/*.js",
    "lint:fix": "eslint *.js services/*.js handlers/*.js --fix",
    "test": "mocha tests/**/*.test.js --timeout 10000",
    "test:socket": "mocha tests/socketHandlers.test.js --timeout 10000",
    "test:room": "mocha tests/roomHandlers.test.js --timeout 10000",
    "test:integration": "node tests/integration-test.js"
  },
  "keywords": [
    "dnd",
    "vtt",
    "multiplayer",
    "socket.io"
  ],
  "author": "DJ-github88",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dompurify": "^3.1.7",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^12.0.0",
    "joi": "^17.11.0",
    "jsdom": "^25.0.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.8.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "chai": "^4.3.10",
    "eslint": "^8.57.0",
    "mocha": "^10.2.0",
    "nodemon": "^3.0.2",
    "sinon": "^17.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
