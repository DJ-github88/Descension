rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own user document
    // SECURITY: Allow authenticated users to read other users to support Friend ID search
    // SECURITY: subscriptionTier field is protected — only server-side updates allowed
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['subscriptionTier', 'subscriptionUpdatedAt']);
      allow update: if request.auth != null && request.auth.uid == userId
        && (!('subscriptionTier' in request.resource.data)
            || request.resource.data.subscriptionTier == resource.data.subscriptionTier)
        && (!('subscriptionUpdatedAt' in request.resource.data)
            || request.resource.data.subscriptionUpdatedAt == resource.data.subscriptionUpdatedAt);
    }

    // ===== PRESENCE TRACKING =====
    // User presence for online/offline status and session tracking
    match /presence/{userId} {
      // Allow reading for authenticated users (to see who's online)
      allow read: if request.auth != null;
      // Allow users to write their own presence
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ===== SOCIAL DATA =====
    match /friendRequests/{requestId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.senderId ||
        request.auth.uid == resource.data.receiverId
      );
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.senderId;
      allow update: if request.auth != null && (
        (request.auth.uid == resource.data.receiverId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
        (request.auth.uid == resource.data.senderId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.senderId ||
        request.auth.uid == resource.data.receiverId
      );
    }

    // ===== CHARACTER DATA PERSISTENCE =====
    // Users can read/write their own characters (stored in top-level characters collection)
    match /characters/{characterId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.metadata.userId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.metadata.userId;
    }

    // Character runtime state (HP, inventory, equipment, etc.)
    match /users/{userId}/characterStates/{characterId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Character sessions for tracking gameplay changes
    match /character_sessions/{sessionId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
    }

    // ===== ROOM DATA PERSISTENCE =====
    // Multiplayer rooms - SECURITY: Restricted to room members only
    match /rooms/{roomId} {
      // Helper function to check if user is room member
      function isRoomMember() {
        return request.auth != null && (
          request.auth.uid == resource.data.gmId ||
          (resource.data.members != null && request.auth.uid in resource.data.members)
        );
      }

      // Allow reading any room for authenticated users (they still need password to join)
      allow read: if request.auth != null;

      // Allow creating rooms (user becomes GM)
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.gmId;

      // SECURITY: Only GM or room members can update gameState
      // GM can update any field, members can only update gameState and lastActivity
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.gmId ||
         (isRoomMember() &&
          'gameState' in request.resource.data &&
          request.resource.data.keys().hasOnly(['gameState', 'lastActivity'])));

      // Allow GM to delete rooms
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.gmId;

      // Subcollections for split storage and chat
      match /gameState/{documentId} {
        allow read, write: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.gmId ||
          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members
        );
      }

      match /chat/{documentId} {
        allow read, write: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.gmId ||
          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members
        );
      }
    }

    // Room runtime state (tokens, items, environmental objects, combat, chat)
    match /users/{userId}/roomStates/{roomId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Room sessions for active multiplayer sessions
    match /roomSessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ===== JOURNAL DATA PERSISTENCE =====
    // User journals (knowledge, notes, boards, folders)
    match /users/{userId}/journal/{document} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ===== CAMPAIGN DATA PERSISTENCE =====
    // User campaigns (GM planning data)
    match /users/{userId}/campaigns/{campaignId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ===== COMMUNITY CONTENT =====

    // Shared campaigns - published campaigns for download (Archmage tier)
    match /sharedCampaigns/{campaignId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.publisherId;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.publisherId ||
        request.resource.data.keys().hasOnly(['downloads'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.publisherId;
    }

    // Public game data (items, spells, etc.) - read only
    match /gameData/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Community spells - allow public read access
    match /community_spells/{spellId} {
      allow read: if resource.data.isPublic == true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Spell categories - allow public read access
    match /spell_categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Spell ratings - allow users to manage their own ratings
    match /spell_ratings/{ratingId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // Community items - allow public read access and community updates for counts
    match /community_items/{itemId} {
      allow read: if true; // Allow all to see public items (service handles isPublic filter)
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['upvotes', 'downvotes', 'commentCount', 'downloadCount'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Item categories - allow public read access
    match /item_categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Item ratings - allow users to manage their own ratings
    match /item_ratings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        // For composite keys like itemId_userId, we check if the doc belongs to user
        ratingId.size() > 28 ? ratingId.endsWith(request.auth.uid) : resource.data.userId == request.auth.uid
      );
    }

    // Item comments - allow public read and authenticated create
    match /item_comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Community creatures - allow public read access
    match /community_creatures/{creatureId} {
      allow read: if resource.data.isPublic == true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Creature categories - allow public read access
    match /creature_categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Creature ratings - allow users to manage their own ratings
    match /creature_ratings/{ratingId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // Community packs - allow public read access
    match /community_packs/{packId} {
      allow read: if resource.data.isPublic == true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Pack ratings - allow users to manage their own ratings
    match /pack_ratings/{ratingId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // ===== USER LIBRARIES =====
    // User libraries - allow users to manage their own libraries
    match /users/{userId}/libraries/{libraryId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User custom spells - allow users to manage their own spells
    match /user_spells/{spellId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
    }

    // User custom items - allow users to manage their own items
    match /userItems/{itemId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
    }

    // User item folders - allow users to manage their own item folders
    match /userItemFolders/{folderId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
    }

    // ===== USER SETTINGS =====
    // User settings and preferences - allow users to manage their own settings
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ===== USER CREATURES =====
    // User custom creatures - allow users to manage their own creatures
    match /userCreatures/{creatureId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
    }

    // User creature folders - allow users to manage their own creature folders
    match /userCreatureFolders/{folderId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
    }

    // ===== USER MAPS =====
    // User custom maps - allow users to manage their own maps
    match /userMaps/{mapId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
    }

    // User map folders - allow users to manage their own map folders
    match /userMapFolders/{folderId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
    }

    // ===== DICE ROLL HISTORY =====
    // Dice rolls - allow users to manage their own roll history
    match /diceRolls/{rollId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
    }

    // Character roll statistics - allow users to manage their own stats
    match /characterRollStats/{statsId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // Roll sessions - allow room members to manage session data
    match /rollSessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.gmId == request.auth.uid
      );
    }

    // ===== USER PROFILES =====
    // User profiles - allow users to manage their own profile data
    match /userProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ===== LEGACY SUPPORT =====
    // Legacy support for characters stored under users subcollection (if any exist)
    match /users/{userId}/characters/{characterId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}